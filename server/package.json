{
  "name": "hms-server",
  "version": "1.0.0",
  "description": "HMS Registration Portal — Backend",
  "main": "server.js",
  "scripts": {
    "start": "node --dns-result-order=ipv4first server.js",
    "dev": "nodemon server.js",
    "migrate": "node scripts/migrate.js",
